# .env.example

# --- Cluster Configuration ---
CLUSTER_NAME=my-cluster
ENVIRONMENT=production
DOMAIN=example.com

# --- Credentials ---
# Traefik Admin Credentials
TRAEFIK_ADMIN_USER=admin
TRAEFIK_ADMIN_PASSWORD=super-secret-password

# OpenObserve Admin Credentials
ZO_ROOT_USER_EMAIL=admin@example.com
ZO_ROOT_USER_PASSWORD=SecurePassword123!

# Portainer Admin Credentials
PORTAINER_ADMIN_PASSWORD=portainer-secret-password


# --- Custom TLS Certificate Paths ---
# Full path to your custom SSL/TLS certificate file (e.g., /home/user/cert.pem)
CERT_PATH=./cert.crt
# Full path to your custom SSL/TLS private key file (e.g., /home/user/key.pem)
KEY_PATH=./key.key
