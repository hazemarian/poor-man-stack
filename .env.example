# ─── Manager node config ──────────────────────────────────────────────────────
# Required when running: ./main-node/setup.sh  (or ./bin/setup.sh manager)

# Cluster
CLUSTER_NAME=my-cluster
ENVIRONMENT=production
DOMAIN=example.com

# Traefik dashboard credentials
TRAEFIK_ADMIN_USER=admin
TRAEFIK_ADMIN_PASSWORD=super-secret-password

# OpenObserve admin credentials
ZO_ROOT_USER_EMAIL=admin@example.com
ZO_ROOT_USER_PASSWORD=SecurePassword123!

# Portainer admin credentials
PORTAINER_ADMIN_PASSWORD=portainer-secret-password

# TLS certificate paths (full path on this machine)
CERT_PATH=./cert.crt
KEY_PATH=./key.key

# ─── Worker node config ───────────────────────────────────────────────────────
# Required when running: ./worker-node/setup.sh  (or ./bin/setup.sh worker)

# IP address of the manager node
MANAGER_IP=1.2.3.4

# Worker join token — get from the manager with: docker swarm join-token worker
SWARM_JOIN_TOKEN=SWMTKN-1-xxxxxx-xxxxxx
